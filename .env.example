# Variáveis de ambiente alternativas ao application-local.properties
# Spring Boot mapeia automaticamente (relaxed binding):
#
#   SPRING_DATASOURCE_PASSWORD  →  spring.datasource.password
#   JWT_SECRET                  →  jwt.secret
#   APP_SUPERADMIN_PASSWORD     →  app.superadmin.password

SPRING_DATASOURCE_PASSWORD=your_mysql_password
JWT_SECRET=your_base64_jwt_secret_here
APP_SUPERADMIN_PASSWORD=ChangeMe@2025!
